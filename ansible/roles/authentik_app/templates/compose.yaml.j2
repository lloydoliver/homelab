{# Managed by authentik_app. Server + worker only; data tier is external. #}
{# NOT host networking: server and worker both bind :9000, so sharing the node's
   netns made them collide (the worker won the bind and served broken pages). On
   the default compose bridge each gets its own netns; only the server's :9000 is
   published for Caddy. They reach the data tier via the node's lab IP, where the
   HAProxy frontends bind (not loopback).
   The blueprints dir is mounted read-only under /blueprints/custom; authentik
   discovers and reconciles every YAML in there (the worker applies them). #}
services:
  server:
    image: {{ authentik_image }}
    restart: unless-stopped
    command: server
    env_file: ./.env
    ports:
      - "9000:9000"
    volumes:
      - {{ authentik_blueprints_dir }}:/blueprints/custom:ro
      - {{ authentik_media_dir }}:/media

  worker:
    image: {{ authentik_image }}
    restart: unless-stopped
    command: worker
    env_file: ./.env
{% if ldaps_cert and ldaps_key %}
    # LDAPS server cert/key for the ldap blueprint's certificatekeypair, read via
    # !Env. Multi-line PEMs can't live in .env (single-line only), so they're set
    # here — the worker is what applies blueprints. This compose file is 0640
    # root:root and is NOT mounted into the container, so the key isn't exposed in a
    # container-readable file. #40 tracks automating this.
    environment:
      LDAPS_CERT: |
        {{ ldaps_cert | indent(8) }}
      LDAPS_KEY: |
        {{ ldaps_key | indent(8) }}
{% endif %}
    volumes:
      - {{ authentik_blueprints_dir }}:/blueprints/custom:ro
      - {{ authentik_media_dir }}:/media
    # No docker.sock mount: embedded-docker outpost management is deliberately
    # off (outposts are deployed as their own Incus services, not via this socket).

  # LDAP outpost — serves the LDAP provider that SSSD on the hosts authenticates
  # against. One instance per app node (HA; SSSD fails over between them). It dials
  # AUTHENTIK_HOST outbound and registers against the outpost defined in the ldap
  # blueprint, matched by AUTHENTIK_TOKEN (the fixed SA token key, from .env — kept
  # out of this 0640 file). Serves LDAP on 3389 and LDAPS on 6636 in-container,
  # published on the standard 389/636 so SSSD can use ldaps://<app-node>:636.
  ldap-outpost:
    image: {{ authentik_ldap_outpost_image }}
    restart: unless-stopped
    environment:
      AUTHENTIK_HOST: "{{ authentik_ldap_outpost_host }}"
      AUTHENTIK_INSECURE: "false"
      AUTHENTIK_TOKEN: "${LDAP_OUTPOST_TOKEN}"
    ports:
      - "389:3389"
      - "636:6636"
