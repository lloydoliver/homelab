{# Managed by authentik_app. Server + worker only; data tier is external. #}
services:
  server:
    image: {{ authentik_image }}
    restart: unless-stopped
    command: server
    env_file: ./.env
    # host networking so the container reaches the node-local HAProxy frontends
    # (127.0.0.1:5000 Postgres / 127.0.0.1:6379 Redis) and exposes the server on
    # the app node's own address for Caddy to balance.
    network_mode: host

  worker:
    image: {{ authentik_image }}
    restart: unless-stopped
    command: worker
    env_file: ./.env
    network_mode: host
    # No docker.sock mount: embedded-docker outpost management is deliberately
    # off (outposts are deployed as their own Incus services, not via this socket).
