{# Managed by authentik_app. #}
AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}

AUTHENTIK_POSTGRESQL__HOST={{ authentik_pg_host }}
AUTHENTIK_POSTGRESQL__PORT={{ authentik_pg_port }}
AUTHENTIK_POSTGRESQL__NAME={{ authentik_pg_name }}
AUTHENTIK_POSTGRESQL__USER={{ authentik_pg_user }}
AUTHENTIK_POSTGRESQL__PASSWORD={{ authentik_pg_password }}

AUTHENTIK_REDIS__HOST={{ authentik_redis_host }}
AUTHENTIK_REDIS__PORT={{ authentik_redis_port }}
AUTHENTIK_REDIS__PASSWORD={{ authentik_redis_password }}

{# akadmin's password on first boot — no manual initial-setup. #}
AUTHENTIK_BOOTSTRAP_PASSWORD={{ authentik_bootstrap_password }}

{# Read by the Headscale blueprint via !Env, so Authentik and the headscale role
   share one source of truth for the OIDC client credentials. #}
HEADSCALE_OIDC_CLIENT_ID={{ headscale_oidc_client_id }}
HEADSCALE_OIDC_CLIENT_SECRET={{ headscale_oidc_client_secret }}

{# Read by the NAS blueprint via !Env. #}
NAS_OIDC_CLIENT_ID={{ nas_oidc_client_id }}
NAS_OIDC_CLIENT_SECRET={{ nas_oidc_client_secret }}
