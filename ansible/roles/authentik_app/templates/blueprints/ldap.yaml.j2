# Managed by the authentik_app role. LDAP provider + outpost for SSSD host auth.
# Hosts run SSSD against the LDAP outpost; users in ssh-users get a POSIX identity
# and can log in (home dirs auto-created by pam_mkhomedir) and sudo (password auth
# against Authentik). The SSH *cert* is signed separately by OpenBao's SSH CA; this
# is the identity/authorisation half.
#
# Fixed outpost token (works around goauthentik/authentik#9711, which has no
# blueprint field to set an outpost token directly). When the outpost saves, its
# post_save signal SYNCHRONOUSLY creates its internal service account — named
# deterministically `Outpost <outpost name> Service-Account` (see
# authentik/outposts/models.py: `name=f"Outpost {self.name} Service-Account"`). So
# within this one transaction, the token entry (after the outpost) !Finds that SA by
# name and sets a fixed `key` from SOPS. The outpost container's AUTHENTIK_TOKEN
# then matches with zero manual steps, single pass.
#
# Do NOT pin the outpost's pk: the pk IS the `uuid` field, and user_identifier does
# `self.uuid.hex` in post_save — a blueprint sets pk as a string, so `.hex` throws.
# Let Authentik assign the uuid; we key off the SA's stable name instead.
version: 1
metadata:
  name: lab - ldap outpost
entries:
  # Per-app access group. Membership grants a POSIX identity + host login. Gates the
  # application (policy binding below) — default-deny, so non-members can't bind.
  - model: authentik_core.group
    id: group-ssh-users
    identifiers:
      name: ssh-users
    attrs:
      name: ssh-users

{% if ldaps_cert and ldaps_key %}
  # LDAPS server cert for the outpost's 6636 listener, from OpenBao's infra PKI role
  # (CN ldap.cypherworks.co.uk, IP SANs = the app nodes SSSD dials). Issued once, held
  # in SOPS, injected via !Env (the multi-line PEMs are set on the worker's compose
  # environment, kept out of any container-readable file). SSSD trusts the OpenBao CA
  # and validates the outpost cert against it. #40 tracks automating the rotation.
  # Guarded on the cert being present: without it the outpost falls back to a
  # self-signed cert on 6636 (fine to stand up; SSSD trust needs the CA-signed one).
  - model: authentik_crypto.certificatekeypair
    id: ldaps-cert
    identifiers:
      name: ldaps-outpost
    attrs:
      name: ldaps-outpost
      certificate_data: !Env LDAPS_CERT
      key_data: !Env LDAPS_KEY
{% endif %}

  # LDAP provider. Field set verified against LDAPProviderSerializer. base_dn is site
  # data (deploy). certificate = the CA-signed keypair above (when present), so both
  # outpost instances serve it on 6636 (replaces the outpost's self-signed default).
  - model: authentik_providers_ldap.ldapprovider
    id: provider-ldap
    identifiers:
      name: LDAP
    attrs:
      name: LDAP
      base_dn: "{{ authentik_ldap_base_dn }}"
{% if ldaps_cert and ldaps_key %}
      certificate: !KeyOf ldaps-cert
{% endif %}
      # The "Bind flow" — reuse the default authentication flow (password stage
      # already includes the LDAPBackend + InbuiltBackend, per the export).
      authorization_flow: !Find [authentik_flows.flow, [slug, default-authentication-flow]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      # cached = run the auth flow then cache the bind (Authentik's documented
      # default); direct = always re-run the flow. Cached is fine for SSSD.
      bind_mode: cached
      search_mode: cached
      # Password-only login (belt-and-braces sudo). MFA-over-LDAP would force users
      # to append a TOTP to the password — not wanted here.
      mfa_support: false
      # POSIX id ranges. uidNumber/gidNumber are derived from these.
      uid_start_number: 2000
      gid_start_number: 4000

  # Application gates who may bind: only ssh-users members (policy binding below).
  - model: authentik_core.application
    id: app-ldap
    identifiers:
      slug: ldap
    attrs:
      name: LDAP
      slug: ldap
      provider: !KeyOf provider-ldap
      policy_engine_mode: any

  - model: authentik_policies.policybinding
    identifiers:
      target: !KeyOf app-ldap
      group: !KeyOf group-ssh-users
      order: 0
    attrs:
      enabled: true

  # LDAP outpost. Identified by name (NOT pk — see header). On save it synchronously
  # creates its internal service account `Outpost LDAP Service-Account`, which the
  # token below binds to. We deploy the outpost container ourselves (its own compose
  # service on the app nodes), so only the meaningful config keys are set; the
  # docker/k8s deployment fields are irrelevant and left to default.
  - model: authentik_outposts.outpost
    id: outpost-ldap
    identifiers:
      name: LDAP
    attrs:
      name: LDAP
      type: ldap
      providers:
        - !KeyOf provider-ldap
      config:
        authentik_host: "{{ authentik_ldap_outpost_host }}"
        authentik_host_insecure: false
        log_level: info

  # A fixed-key API token (from SOPS via !Env) on the outpost's auto-created SA — the
  # outpost container's AUTHENTIK_TOKEN. !Find resolves the SA by its deterministic
  # name (must match "Outpost <outpost name above> Service-Account"), created in this
  # same transaction by the outpost's save. The outpost also mints its own random
  # token; this is a second, known one so the container's token is IaC-managed.
  - model: authentik_core.token
    identifiers:
      identifier: ldap-outpost-api
    attrs:
      user: !Find [authentik_core.user, [name, "Outpost LDAP Service-Account"]]
      intent: api
      key: !Env LDAP_OUTPOST_TOKEN
      expiring: false
      description: LDAP outpost API token (managed by the ldap blueprint)
