{# Managed by the monitoring role. Secrets for compose ${...} interpolation. #}
GRAFANA_ADMIN_PASSWORD={{ monitoring_grafana_admin_password }}
GRAFANA_OIDC_CLIENT_ID={{ monitoring_grafana_oidc_client_id }}
GRAFANA_OIDC_CLIENT_SECRET={{ monitoring_grafana_oidc_client_secret }}
REDIS_PASSWORD={{ monitoring_redis_password }}
SNMP_V3_AUTH_PASSWORD={{ monitoring_snmp_v3_auth_password }}
SNMP_V3_PRIV_PASSWORD={{ monitoring_snmp_v3_priv_password }}
GO2RTC_FRONT_URL={{ monitoring_go2rtc_front_url }}
GO2RTC_GARAGE_CARPORT_URL={{ monitoring_go2rtc_garage_carport_url }}
{% if monitoring_go2rtc_username %}
GO2RTC_USERNAME={{ monitoring_go2rtc_username }}
GO2RTC_PASSWORD={{ monitoring_go2rtc_password }}
{% endif %}
