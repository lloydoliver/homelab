{# Managed by the monitoring role. vmsingle (store+scrape) → vmalert (rules) →
   Alertmanager → alertmanager-ntfy → ntfy; Grafana reads vmsingle. Secrets via
   ./.env interpolation. #}
services:
  vmsingle:
    image: {{ monitoring_vmsingle_image }}
    restart: unless-stopped
    command:
      - "--storageDataPath=/victoria-metrics-data"
      - "--retentionPeriod={{ monitoring_retention }}"
      - "--promscrape.config=/etc/vm/scrape.yml"
      - "--httpListenAddr=:8428"
    volumes:
      - vmdata:/victoria-metrics-data
      - {{ monitoring_config_dir }}/scrape.yml:/etc/vm/scrape.yml:ro
    ports:
      - "8428:8428"

  vmalert:
    image: {{ monitoring_vmalert_image }}
    restart: unless-stopped
    command:
      - "--datasource.url=http://vmsingle:8428"
      - "--remoteWrite.url=http://vmsingle:8428"
      - "--notifier.url=http://alertmanager:9093"
      - "--rule=/etc/vmalert/alert-rules.yml"
    volumes:
      - {{ monitoring_config_dir }}/alert-rules.yml:/etc/vmalert/alert-rules.yml:ro
    depends_on:
      - vmsingle
      - alertmanager

  alertmanager:
    image: {{ monitoring_alertmanager_image }}
    restart: unless-stopped
    command:
      - "--config.file=/etc/alertmanager/alertmanager.yml"
    volumes:
      - {{ monitoring_config_dir }}/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
      - amdata:/alertmanager
    depends_on:
      - ntfy

  # Alertmanager posts directly to ntfy's built-in "alertmanager" template — no
  # bridge container (see alertmanager.yml).
  ntfy:
    image: {{ monitoring_ntfy_image }}
    restart: unless-stopped
    command: ["serve"]
    volumes:
      - {{ monitoring_config_dir }}/ntfy.yml:/etc/ntfy/server.yml:ro
      - ntfycache:/var/cache/ntfy
      - ntfydata:/var/lib/ntfy
    ports:
      - "8080:80"

  redis_exporter:
    image: {{ monitoring_redis_exporter_image }}
    restart: unless-stopped
    environment:
      REDIS_PASSWORD: "${REDIS_PASSWORD}"
    ports:
      - "9121:9121"

  # https cert-expiry probes. vmsingle drives it via the blackbox-https scrape job.
  blackbox:
    image: {{ monitoring_blackbox_image }}
    restart: unless-stopped
    command:
      - "--config.file=/etc/blackbox/blackbox.yml"
    volumes:
      - {{ monitoring_config_dir }}/blackbox.yml:/etc/blackbox/blackbox.yml:ro

  # Synology NAS over SNMPv3. snmp.yml carries the module OIDs; the v3 auth/priv
  # passwords come from the container env (./.env) and are expanded into the config
  # at load time via --config.expand-environment-variables, so no plaintext secrets
  # land in the on-disk config file.
  snmp_exporter:
    image: {{ monitoring_snmp_exporter_image }}
    restart: unless-stopped
    command:
      - "--config.file=/etc/snmp_exporter/snmp.yml"
      - "--config.expand-environment-variables"
    environment:
      SNMP_V3_AUTH_PASSWORD: "${SNMP_V3_AUTH_PASSWORD}"
      SNMP_V3_PRIV_PASSWORD: "${SNMP_V3_PRIV_PASSWORD}"
    volumes:
      - {{ monitoring_config_dir }}/snmp.yml:/etc/snmp_exporter/snmp.yml:ro

  # RTSP→MSE/WebRTC/HLS restream for the CCTV strip. The camera RTSP URLs carry
  # access tokens, so they come from the container env (./.env) and go2rtc expands
  # the ${...} placeholders in go2rtc.yaml at load time — no plaintext on disk.
  # Reached only via Caddy on the lab domain; the embed uses MSE (single HTTP port).
  go2rtc:
    image: {{ monitoring_go2rtc_image }}
    restart: unless-stopped
    environment:
      GO2RTC_FRONT_URL: "${GO2RTC_FRONT_URL}"
      GO2RTC_GARAGE_CARPORT_URL: "${GO2RTC_GARAGE_CARPORT_URL}"
{% if monitoring_go2rtc_username %}
      GO2RTC_USERNAME: "${GO2RTC_USERNAME}"
      GO2RTC_PASSWORD: "${GO2RTC_PASSWORD}"
{% endif %}
    volumes:
      - {{ monitoring_config_dir }}/go2rtc.yaml:/config/go2rtc.yaml:ro
    ports:
      - "{{ monitoring_go2rtc_api_port }}:{{ monitoring_go2rtc_api_port }}"

  grafana:
    image: {{ monitoring_grafana_image }}
    restart: unless-stopped
    env_file: ./.env
    environment:
      GF_SERVER_ROOT_URL: "{{ monitoring_grafana_root_url }}"
      GF_SECURITY_ADMIN_USER: "{{ monitoring_grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "${GRAFANA_ADMIN_PASSWORD}"
      GF_AUTH_GENERIC_OAUTH_ENABLED: "true"
      GF_AUTH_GENERIC_OAUTH_NAME: "Authentik"
      GF_AUTH_GENERIC_OAUTH_CLIENT_ID: "${GRAFANA_OIDC_CLIENT_ID}"
      GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: "${GRAFANA_OIDC_CLIENT_SECRET}"
      GF_AUTH_GENERIC_OAUTH_SCOPES: "openid profile email"
      GF_AUTH_GENERIC_OAUTH_AUTH_URL: "{{ monitoring_grafana_oidc_auth_url }}"
      GF_AUTH_GENERIC_OAUTH_TOKEN_URL: "{{ monitoring_grafana_oidc_token_url }}"
      GF_AUTH_GENERIC_OAUTH_API_URL: "{{ monitoring_grafana_oidc_api_url }}"
      GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH: "{{ monitoring_grafana_role_path }}"
      GF_AUTH_SIGNOUT_REDIRECT_URL: "{{ monitoring_grafana_oidc_signout_url }}"
      # Allow the CCTV text panel to render its go2rtc <iframe>. Scoped to the text
      # panel only; Grafana stays behind Authentik OIDC. Not allow_embedding — that's
      # for embedding Grafana elsewhere, which we don't do.
      GF_PANELS_DISABLE_SANITIZE_HTML: "true"
    volumes:
      - grafanadata:/var/lib/grafana
      - {{ monitoring_config_dir }}/grafana/provisioning:/etc/grafana/provisioning:ro
      - {{ monitoring_config_dir }}/grafana/dashboards:/var/lib/grafana/dashboards:ro
    ports:
      - "3000:3000"
    depends_on:
      - vmsingle

volumes:
  vmdata:
  amdata:
  ntfycache:
  ntfydata:
  grafanadata:
