{# Managed by the monitoring role. Auth required — no anonymous access. The user
   DB persists on the ntfydata volume; the alertmanager + human users and their
   topic ACLs are provisioned by the role's tasks (ntfy user add / ntfy access). #}
base-url: "{{ monitoring_ntfy_base_url }}"
listen-http: ":80"
behind-proxy: true
cache-file: "/var/cache/ntfy/cache.db"
auth-file: "/var/lib/ntfy/user.db"
auth-default-access: "deny-all"
