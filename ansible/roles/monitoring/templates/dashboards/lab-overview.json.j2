{% raw %}
{
  "uid": "lab-overview",
  "title": "Lab Overview",
  "tags": ["kiosk"],
  "schemaVersion": 39,
  "version": 4,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 90,
      "type": "text",
      "title": "Front CCTV",
      "description": "Pinned top strip — stays visible across the playlist rotation (duplicated on every rotated dashboard). Placeholder until the go2rtc stream lands (task #18).",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Front CCTV\n_Live feed parked — go2rtc stream arrives with task #18. This strip is reserved 16:9 and pinned to the top of every rotated dashboard._"
      }
    },
    {
      "id": 1,
      "type": "table",
      "title": "Hosts",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 7 },
      "targets": [
        { "refId": "up", "expr": "up{job=\"node\"}", "instant": true, "format": "table" },
        { "refId": "cpu", "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))", "instant": true, "format": "table" },
        { "refId": "ram", "expr": "100 * (1 - avg by (instance) (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "instant": true, "format": "table" },
        { "refId": "disk", "expr": "100 * (1 - max by (instance) (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{mountpoint=\"/\"}))", "instant": true, "format": "table" },
        { "refId": "net", "expr": "sum by (instance) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m]) + rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m]))", "instant": true, "format": "table" },
        { "refId": "load", "expr": "max by (instance) (node_load1)", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "__name__": true },
            "renameByName": {
              "instance": "Host",
              "Value #up": "Status",
              "Value #cpu": "CPU %",
              "Value #ram": "RAM %",
              "Value #disk": "Disk %",
              "Value #net": "Net B/s",
              "Value #load": "Load (1m)"
            },
            "indexByName": {
              "instance": 0, "Value #up": 1, "Value #cpu": 2, "Value #ram": 3,
              "Value #disk": 4, "Value #net": 5, "Value #load": 6
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "center" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "(CPU|RAM|Disk) %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Net B/s" },
            "properties": [ { "id": "unit", "value": "Bps" }, { "id": "decimals", "value": 0 } ]
          },
          {
            "matcher": { "id": "byName", "options": "Load (1m)" },
            "properties": [
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 4 }, { "color": "red", "value": 8 } ] } }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Host" } ] }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Service targets up",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "up{job=~\"blocky|patroni|etcd|redis|headscale\"}", "legendFormat": "{{job}} {{instance}}", "instant": true }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "HA health (degraded = amber)",
      "description": "Folds the HA tier into up/degraded states: Patroni primary present, Redis master present, etcd quorum (a leader is visible), blocky up, Headscale up.",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DEGRADED", "color": "orange" }, "1": { "text": "OK", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "clamp_max(sum(patroni_primary), 1)", "legendFormat": "Patroni primary", "instant": true },
        { "refId": "B", "expr": "clamp_max(count(redis_instance_info{role=\"master\"}), 1)", "legendFormat": "Redis master", "instant": true },
        { "refId": "C", "expr": "clamp_max(max(etcd_server_has_leader), 1)", "legendFormat": "etcd quorum", "instant": true },
        { "refId": "D", "expr": "clamp_max(sum(up{job=\"blocky\"}), 1)", "legendFormat": "blocky", "instant": true },
        { "refId": "E", "expr": "clamp_max(sum(up{job=\"headscale\"}), 1)", "legendFormat": "Headscale", "instant": true }
      ]
    },
    {
      "id": 30,
      "type": "stat",
      "title": "TLS cert expiry (days)",
      "description": "blackbox probe_ssl_earliest_cert_expiry is a unix timestamp; days = (expiry - now) / 86400.",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 14 }, { "color": "green", "value": 30 } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400", "legendFormat": "{{instance}}", "instant": true }
      ]
    }
  ]
}
{% endraw %}
