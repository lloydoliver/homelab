#!/bin/sh
# Managed by the keepalived role. VRRP track_script liveness check: is the local
# resolver actually answering? A real query (unlike `systemctl is-active`) catches
# a HUNG blocky as well as a crashed one — important when the rig runs hot.
#
# +norecurse keeps it a pure responsiveness test (no upstream dependency), so an
# upstream outage doesn't cause a needless failover; it fails only when blocky
# itself stops replying within the timeout. dig exits non-zero on no-reply, which
# drops this node's VRRP priority and hands the VIP to the peer.
exec dig +tries=1 +time=2 +norecurse @127.0.0.1 . NS >/dev/null 2>&1
