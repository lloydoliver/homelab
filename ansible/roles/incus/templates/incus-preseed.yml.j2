{# Fed to `incus admin init --preseed` on first init only (guarded by the task). #}
config:
  core.https_address: "{{ incus_https_address }}"
storage_pools:
  - name: {{ incus_storage_pool }}
    driver: btrfs
    config:
      source: /dev/{{ incus_storage_vg }}/{{ incus_storage_lv }}
profiles:
  - name: default
    devices:
      root:
        path: /
        pool: {{ incus_storage_pool }}
        type: disk
