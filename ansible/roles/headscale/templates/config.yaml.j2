{# Headscale control-plane config. Managed by the headscale role. #}
server_url: https://{{ headscale_domain }}
listen_addr: {{ headscale_listen_addr }}
metrics_listen_addr: {{ headscale_metrics_listen_addr }}
grpc_listen_addr: 127.0.0.1:50443

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48

# Self-hosted relay only — no public Tailscale DERP servers.
derp:
  server:
    enabled: true
    region_id: 999
    region_code: "lab"
    region_name: "Lab Embedded DERP"
    stun_listen_addr: 0.0.0.0:3478
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
  urls: []
  auto_update_enabled: false

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite

# Cert on 443 via TLS-ALPN-01 — no port 80, nothing else exposed.
tls_letsencrypt_hostname: {{ headscale_domain }}
tls_letsencrypt_cache_dir: /var/lib/headscale/cache
tls_letsencrypt_challenge_type: TLS-ALPN-01

dns:
  magic_dns: true
  base_domain: {{ headscale_base_domain }}
  nameservers:
    global:
      - 1.1.1.1
{% if headscale_oidc_enabled %}

# MFA + device identity happen here: enrolment redirects to Authentik (reached via
# the EC2 passthrough), which enforces MFA. Only allowed_groups get authorised.
oidc:
  only_start_if_oidc_is_available: {{ headscale_oidc_only_start_if_available | string | lower }}
  issuer: {{ headscale_oidc_issuer }}
  client_id: {{ headscale_oidc_client_id }}
  client_secret: {{ headscale_oidc_client_secret }}
  scope: {{ headscale_oidc_scopes | to_json }}
  allowed_groups:
{% for group in headscale_oidc_allowed_groups %}
    - {{ group }}
{% endfor %}
{% endif %}
